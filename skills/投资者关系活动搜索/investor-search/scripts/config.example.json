    "api_key": "IWENCAI_API_KEY",
    "http_proxy": "HTTP_PROXY",
    "https_proxy": "HTTPS_PROXY"
  },
  
  "cli_config": {
    "program_name": "investor-search",
    "version": "1.0.0",
    "description": "investor搜索工具 - 搜索A股上市公司投资者关系相关内容",
    "epilog": "使用示例:\n  investor-search \"贵州茅台投资者关系活动\"\n  investor-search \"人工智能公司调研\" --company \"科大讯飞\" --date-start \"2024-01-01\"\n  investor-search \"新能源行业路演\" --output \"results.csv\" --format csv\n  investor-search --input-file \"queries.txt\" --output-dir \"results/\""
